# ─────────────────────────────────────────────────────────────────────────────
# ZipAI External Data API — Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# WARNING: Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (RDS) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:etMMmbciCR9HsImJZ9sL@zipdata-prod.cizaqgaqkt3u.us-east-1.rds.amazonaws.com:5432/zipdata
DB_SCHEMA=healthcare

# ── AWS Credentials ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=                     # Uncomment if using temporary credentials

# ── AWS Bedrock — Model IDs ─────────────────────────────────────────────────
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_CONCURRENCY=10

# ── Chunking Strategy ───────────────────────────────────────────────────────
MAX_CHUNK_TOKENS=512
MIN_CHUNK_TOKENS=50
OVERLAP_TOKENS=50

# ── RAG Retrieval ────────────────────────────────────────────────────────────
RAG_TOP_K=5
CHAT_HISTORY_WINDOW=6

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production                       # development | staging | production
LOG_LEVEL=info                           # debug | info | warning | error
SERVICE_NAME=zipai-rag

# ── Docker Runtime ───────────────────────────────────────────────────────────
API_PORT=8001                            # Host port mapped to the container
UVICORN_WORKERS=4                        # Number of Uvicorn worker processes

# ── Fee Schedule Pipeline ────────────────────────────────────────────────────
FEE_TOP_K=10
FEE_EMBED_ON_INGEST=true

# ── MLO Encryption ───────────────────────────────────────────────────────────
MLO_ENCRYPTION_PASSWORD=your-encryption-password
