# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (RDS)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://${{ secrets.DB_USER }}:${{ secrets.DB_PASSWORD }}@${{ secrets.DB_HOST }}:5432/${{ secrets.DB_NAME }}
DB_SCHEMA=healthcare                          # PostgreSQL schema for this microservice
 
# ─────────────────────────────────────────────────────────────────────────────
# AWS Credentials
# ─────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=                     # Uncomment if using temporary credentials
 
# ─────────────────────────────────────────────────────────────────────────────
# AWS Bedrock — Model IDs
# ─────────────────────────────────────────────────────────────────────────────
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_CONCURRENCY=10
 
# ─────────────────────────────────────────────────────────────────────────────
# Chunking Strategy
# ─────────────────────────────────────────────────────────────────────────────
MAX_CHUNK_TOKENS=512
MIN_CHUNK_TOKENS=50
OVERLAP_TOKENS=50
 
# ─────────────────────────────────────────────────────────────────────────────
# RAG Retrieval
# ─────────────────────────────────────────────────────────────────────────────
RAG_TOP_K=5                            # Number of chunks to retrieve per query
CHAT_HISTORY_WINDOW=6                  # Number of past messages to include in context
 
# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
LOG_LEVEL=debug                        # debug | info | warning | error
SERVICE_NAME=zipai-rag
 
# ─────────────────────────────────────────────────────────────────────────────
# S3 (Phase 2 — batch ingestion, not active yet)
# ─────────────────────────────────────────────────────────────────────────────
# S3_BUCKET_NAME=zipai-permits
# S3_PREFIX=california/
 
# ─────────────────────────────────────────────────────────────────────────────
# Fee Schedule Pipeline
# ─────────────────────────────────────────────────────────────────────────────
FEE_TOP_K=10                           # Max fee records returned per query
FEE_EMBED_ON_INGEST=true               # Generate Titan embeddings at ingestion time
                                       # Set to false for SQL-only mode (faster ingest)
